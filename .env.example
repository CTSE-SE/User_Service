# --- Server ----------------------------------------
PORT=3002
NODE_ENV=development

# --- Database (PostgreSQL) -------------------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=user_service_db
DB_USER=postgres
DB_PASSWORD=your_db_password

# --- Authentication -------------------------------
JWT_SECRET=your_super_secret_jwt_key
JWT_EXPIRES_IN=1d

# --- Client / Frontend -----------------------------
CLIENT_URL=http://localhost:5173

# --- Internal Service Communication ----------------
INTERNAL_API_KEY=your_internal_api_key_shared_with_services

# --- API Documentation -----------------------------
API_BASE_URL=http://localhost:3002

# --- Optional Logging ------------------------------
LOG_LEVEL=info